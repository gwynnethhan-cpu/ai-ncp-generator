Backend Code (server.js)
Copy everything below:

import express from "express";
import cors from "cors";
import helmet from "helmet";
import rateLimit from "express-rate-limit";
import dotenv from "dotenv";
import OpenAI from "openai";

dotenv.config();

const app = express();
const PORT = process.env.PORT || 3000;
const FRONTEND_ORIGIN = process.env.FRONTEND_ORIGIN || "null";
const SESSION_PASSWORD = process.env.APP_PASSWORD || "change-this-password";
const SESSION_TIMEOUT_MS = 15 * 60 * 1000;

const openai = process.env.OPENAI_API_KEY
  ? new OpenAI({ apiKey: process.env.OPENAI_API_KEY })
  : null;

const sessions = new Map();

app.disable("x-powered-by");

app.use(helmet());

app.use(express.json({ limit: "100kb" }));

app.use(cors({
  origin(origin, callback) {
    if (!origin || origin === "null" || origin === FRONTEND_ORIGIN) {
      return callback(null, true);
    }
    return callback(new Error("Origin not allowed"));
  }
}));

app.use(rateLimit({
  windowMs: 15 * 60 * 1000,
  max: 100
}));

const aiLimiter = rateLimit({
  windowMs: 15 * 60 * 1000,
  max: 20
});

function generateSessionId() {
  return `${Date.now()}-${Math.random().toString(36).slice(2)}`;
}

function cleanText(value, maxLength = 2000) {
  if (typeof value !== "string") return "";

  return value
    .replace(/[<>]/g, "")
    .replace(/\s+/g, " ")
    .trim()
    .slice(0, maxLength);
}

function redactPatientData(payload) {
  return {
    age: cleanText(payload.age, 50),
    medicalDiagnosis: cleanText(payload.medicalDiagnosis, 300),
    history: cleanText(payload.history, 1000),
    subjectiveData: cleanText(payload.subjectiveData, 1500),
    objectiveData: cleanText(payload.objectiveData, 1500)
  };
}

function validateCaseInput(payload) {
  const cleaned = redactPatientData(payload);

  if (!cleaned.subjectiveData && !cleaned.objectiveData && !cleaned.medicalDiagnosis) {
    return { ok: false, error: "Insufficient clinical data." };
  }

  return { ok: true, data: cleaned };
}

function authMiddleware(req, res, next) {

  const authHeader = req.headers.authorization || "";
  const token = authHeader.startsWith("Bearer ") ? authHeader.slice(7) : "";

  const session = sessions.get(token);

  if (!session) {
    return res.status(401).json({ error: "Unauthorized" });
  }

  if (Date.now() - session.lastSeen > SESSION_TIMEOUT_MS) {
    sessions.delete(token);
    return res.status(401).json({ error: "Session expired" });
  }

  session.lastSeen = Date.now();

  next();
}

app.get("/health", (_req, res) => {
  res.json({
    ok: true,
    aiReady: Boolean(openai)
  });
});

app.post("/login", (req, res) => {

  const password = cleanText(req.body?.password, 200);

  if (!password || password !== SESSION_PASSWORD) {
    return res.status(401).json({ error: "Invalid password" });
  }

  const sessionId = generateSessionId();

  sessions.set(sessionId, {
    createdAt: Date.now(),
    lastSeen: Date.now()
  });

  res.json({
    token: sessionId,
    expiresInMs: SESSION_TIMEOUT_MS
  });
});

app.post("/logout", authMiddleware, (req, res) => {

  const authHeader = req.headers.authorization || "";
  const token = authHeader.startsWith("Bearer ") ? authHeader.slice(7) : "";

  sessions.delete(token);

  res.json({ ok: true });

});

app.post("/generate-ncp", authMiddleware, aiLimiter, async (req, res) => {

  const validation = validateCaseInput(req.body || {});

  if (!validation.ok) {
    return res.status(400).json({ error: validation.error });
  }

  const clinicalData = validation.data;

  if (!openai) {
    return res.status(503).json({ error: "OpenAI API key missing" });
  }

  try {

    const response = await openai.responses.create({

      model: "gpt-5-mini",

      input: `Generate a nursing care plan suggestion based on:

Age: ${clinicalData.age}
Medical Diagnosis: ${clinicalData.medicalDiagnosis}

Subjective:
${clinicalData.subjectiveData}

Objective:
${clinicalData.objectiveData}

Return JSON with:
nursingDiagnosis
rationaleNotes
interventions
implementationSuggestions`

    });

    const text = response.output_text;

    res.json({
      nursingDiagnosis: text
    });

  } catch (error) {

    console.error(error);

    res.status(500).json({
      error: "AI generation failed"
    });

  }

});

app.listen(PORT, () => {
  console.log(`Secure NCP backend listening on http://localhost:${PORT}`);
});
